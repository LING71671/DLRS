{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dlrs.standard/schemas/manifest.schema.json",
  "title": "DLRS Human Record Manifest",
  "description": "Top-level manifest for a single DLRS human record. Every archive directory under humans/ MUST contain exactly one manifest.json conforming to this schema.",
  "type": "object",
  "required": [
    "schema_version",
    "record_id",
    "visibility",
    "subject",
    "rights",
    "consent",
    "artifacts",
    "deletion_policy",
    "inheritance_policy",
    "security",
    "review",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "DLRS schema version this manifest conforms to (semver). v0.3 accepts 0.2.x and 0.3.x while migration is in progress.",
      "pattern": "^0\\.[23]\\.\\d+$",
      "examples": ["0.2.0", "0.3.0"]
    },
    "record_id": {
      "type": "string",
      "description": "Stable record identifier. Format: dlrs_<slug>. MUST be globally unique across the registry.",
      "pattern": "^dlrs_[a-zA-Z0-9_-]{4,}$",
      "examples": ["dlrs_94f1c9b8", "dlrs_94f1c9b8_lin-example"]
    },
    "display_slug": {
      "type": "string",
      "description": "Optional human-friendly slug used for the directory name."
    },
    "visibility": {
      "type": "string",
      "description": "Top-level visibility for the record. Drives whether the registry generator considers the record at all.",
      "enum": [
        "private",
        "team",
        "public_indexed",
        "public_unlisted"
      ]
    },
    "subject": {
      "type": "object",
      "required": [
        "type",
        "display_name",
        "locale",
        "residency_region",
        "is_minor",
        "status"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "self",
            "authorized_agent",
            "estate_authorized",
            "public_data_only"
          ]
        },
        "display_name": {
          "type": "string"
        },
        "legal_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "locale": {
          "type": "string"
        },
        "residency_region": {
          "type": "string"
        },
        "is_minor": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "living",
            "deceased",
            "unknown",
            "incapacitated"
          ]
        }
      },
      "additionalProperties": true
    },
    "rights": {
      "type": "object",
      "required": [
        "uploader_role",
        "rights_basis",
        "evidence_refs",
        "allow_public_listing",
        "allow_commercial_use",
        "allow_model_finetune",
        "allow_voice_clone",
        "allow_avatar_clone",
        "cross_border_transfer_basis"
      ],
      "properties": {
        "uploader_role": {
          "type": "string"
        },
        "rights_basis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow_public_listing": {
          "type": "boolean"
        },
        "allow_commercial_use": {
          "type": "boolean"
        },
        "allow_model_finetune": {
          "type": "boolean"
        },
        "allow_voice_clone": {
          "type": "boolean"
        },
        "allow_avatar_clone": {
          "type": "boolean"
        },
        "allow_research_use": {
          "type": "boolean"
        },
        "cross_border_transfer_basis": {
          "type": "string",
          "enum": [
            "none",
            "consent_only",
            "standard_contract",
            "certification",
            "security_assessment",
            "other_lawful_basis"
          ]
        },
        "cross_border_transfer_status": {
          "type": "string",
          "enum": [
            "not_needed",
            "pending",
            "approved",
            "blocked"
          ]
        }
      },
      "additionalProperties": true
    },
    "consent": {
      "type": "object",
      "required": [
        "captured_at",
        "withdrawal_endpoint",
        "separate_biometric_consent"
      ],
      "properties": {
        "captured_at": {
          "type": "string"
        },
        "withdrawal_endpoint": {
          "type": "string",
          "minLength": 3
        },
        "separate_biometric_consent": {
          "type": "boolean"
        },
        "guardian_consent": {
          "type": "boolean"
        },
        "consent_version": {
          "type": "string"
        },
        "allowed_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "type",
          "format",
          "storage_uri",
          "checksum",
          "region",
          "sensitivity"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "storage_uri": {
            "type": "string"
          },
          "checksum": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "sensitivity": {
            "type": "string",
            "enum": [
              "S0_PUBLIC",
              "S1_INTERNAL",
              "S2_SENSITIVE",
              "S3_BIOMETRIC",
              "S4_RESTRICTED"
            ]
          },
          "contains_sensitive_data": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "deletion_policy": {
      "type": "object",
      "required": [
        "allow_delete",
        "allow_export",
        "withdrawal_effect"
      ],
      "properties": {
        "allow_delete": {
          "type": "boolean"
        },
        "allow_export": {
          "type": "boolean"
        },
        "withdrawal_effect": {
          "type": "string",
          "enum": [
            "freeze_runtime_then_delete",
            "freeze_runtime_keep_archive",
            "delete_all_nonlegal_holds"
          ]
        },
        "legal_hold": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "inheritance_policy": {
      "type": "object",
      "required": [
        "policy_ref",
        "default_action_on_death",
        "executor_contact_ref"
      ],
      "properties": {
        "policy_ref": {
          "type": "string"
        },
        "default_action_on_death": {
          "type": "string",
          "enum": [
            "freeze",
            "delete",
            "memorial_private",
            "memorial_public_review_required"
          ]
        },
        "executor_contact_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "security": {
      "type": "object",
      "required": [
        "primary_region",
        "encryption_at_rest",
        "watermark_policy",
        "c2pa_enabled"
      ],
      "properties": {
        "primary_region": {
          "type": "string"
        },
        "replication_regions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "encryption_at_rest": {
          "type": "boolean"
        },
        "kms_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "watermark_policy": {
          "type": "string"
        },
        "c2pa_enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "required": [
        "status",
        "verified_consent_badge",
        "public_data_only_badge",
        "risk_level"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "submitted",
            "blocked",
            "approved_private",
            "approved_public"
          ]
        },
        "verified_consent_badge": {
          "type": "boolean"
        },
        "public_data_only_badge": {
          "type": "boolean"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reviewer_notes_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "created_at",
        "last_modified_at",
        "change_log_hash"
      ],
      "properties": {
        "created_at": {
          "type": "string"
        },
        "last_modified_at": {
          "type": "string"
        },
        "change_log_hash": {
          "type": "string"
        },
        "events_log_ref": {
          "type": ["string", "null"],
          "description": "Relative path to the append-only audit events file (typically audit/events.jsonl). v0.4+ records SHOULD set this; the file format follows schemas/audit-event.schema.json."
        }
      },
      "additionalProperties": true
    },
    "public_disclosure": {
      "type": "object",
      "description": "AI-content disclosure declaration required by EU AI Act \u00a750 and Chinese deep-synthesis rules. v0.4 makes this field machine-checkable for any record whose visibility is public_indexed or public_unlisted. The standard does not yet mandate that the watermark itself be implemented; it does mandate the declaration.",
      "required": [
        "ai_disclosure",
        "label_text_required"
      ],
      "properties": {
        "ai_disclosure": {
          "type": "string",
          "description": "Strongest disclosure obligation that public outputs of this record MUST carry. visible_label_required = displayed text is enough; visible_label_and_watermark = displayed text plus implicit media watermark; c2pa_required = additionally requires C2PA / Content Credentials embedding.",
          "enum": [
            "visible_label_required",
            "visible_label_and_watermark",
            "c2pa_required"
          ]
        },
        "label_text_required": {
          "type": "string",
          "description": "Minimum visible label text that public outputs (text, audio prefix, video overlay) MUST display. Localised variants MAY be added.",
          "minLength": 2,
          "examples": ["AI generated", "AI \u751f\u6210\u5185\u5bb9"]
        },
        "label_locales": {
          "type": "array",
          "description": "Additional locale-specific label texts to display when the audience locale matches.",
          "items": {
            "type": "object",
            "required": ["locale", "label"],
            "properties": {
              "locale": {"type": "string"},
              "label": {"type": "string", "minLength": 2}
            },
            "additionalProperties": false
          }
        },
        "watermark_methods": {
          "type": "array",
          "description": "Declared (not necessarily implemented) implicit-watermark methods that the publishing pipeline SHOULD apply. v0.4 records the declaration; v1.0+ tooling will emit the actual marks.",
          "items": {
            "type": "string",
            "enum": [
              "none",
              "audioseal",
              "meta_seal",
              "image_invisible_watermark",
              "video_invisible_watermark",
              "text_zero_width_marker",
              "vendor_classifier_only"
            ]
          }
        },
        "c2pa_claim_generator": {
          "type": ["string", "null"],
          "description": "Identifier of the C2PA claim generator that will sign public outputs (e.g. 'dlrs-reference-publisher/0.4'). MAY be null if c2pa_required is not selected."
        },
        "impersonation_disclaimer": {
          "type": "string",
          "description": "Standing disclaimer to attach to outputs warning that the AI persona does not represent the real-time, complete, or final intent of the data subject.",
          "minLength": 8
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "visibility": {"enum": ["public_indexed", "public_unlisted"]}
        }
      },
      "then": {
        "required": ["public_disclosure"]
      }
    }
  ],
  "additionalProperties": true
}
